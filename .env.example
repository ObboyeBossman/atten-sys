# ============================================================
# ATTEN-SYS — Environment Variables Template
# Copy this to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# --- Supabase ---
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Cloudflare R2 (S3-compatible object storage) ---
# Found in: Cloudflare Dashboard → R2 → Manage API Tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# The public URL for your R2 bucket (e.g. https://pub-xxxx.r2.dev)
R2_PUBLIC_URL=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Seed / Dev only ---
# Guards the POST /api/seed-user endpoint. Generate with: openssl rand -hex 32
# Leave empty in production or set to a long random value and keep it secret.
SEED_SECRET=
