# ============================================================
# ATTEN-SYS — .gitignore
# ============================================================

# ── Dependencies ──────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# ── Build outputs ─────────────────────────────────────────
.next/
out/
build/
dist/

# ── Environment & secrets ─────────────────────────────────
.env
.env.local
.env.*.local
.env.development
.env.test
.env.production

# ── Supabase ─────────────────────────────────────────────
supabase/.temp/
supabase/.branches/

# ── Testing ───────────────────────────────────────────────
coverage/

# ── PWA / next-pwa generated files ───────────────────────
public/sw.js
public/sw.js.map
public/workbox-*.js
public/workbox-*.js.map
public/worker-*.js
public/worker-*.js.map
public/fallback-*.js
public/fallback-*.js.map

# ── TypeScript ────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── OS / editor ───────────────────────────────────────────
.DS_Store
Thumbs.db
*.pem
.idea/
.vscode/settings.json

# ── Logs ─────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ── Vercel ───────────────────────────────────────────────
.vercel

# ── AI Studio / Google tooling (do not track) ────────────
.aistudio/
metadata.json
